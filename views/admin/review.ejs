<%- include('../partials/navbar_admin') %>

<% if (!products || products.length === 0) { %>
  <p>Tidak ada produk atau review ditemukan.</p>
<% } else { %>

  <% products.forEach(product => { %>
    <div class="product-box" style="margin-bottom: 20px; border-bottom: 2px solid #ccc; padding-bottom: 10px;">
      <h3>Produk: <%= product.name %></h3>

      <% if (product.reviews && product.reviews.length > 0) { %>
        <% product.reviews.forEach((review, index) => { %>
          <div class="review-item" style="margin-left: 20px; margin-top: 10px;">
            <p><strong><%= review.name %></strong> - Rating: <%= review.rating %>/5</p>
            <p><%= review.comment %></p>
            <p><small><%= review.date ? review.date.toLocaleString() : '' %></small></p>

            <% if (review.reply && review.reply.length > 0) { %>
              <div class="reply-box" style="margin-left: 20px; color: gray;">
                <% review.reply.forEach(rep => { %>
                  <p>↳ <strong><%= rep.name %>:</strong> <%= rep.comment %></p>
                  <% if (rep.date) { %>
                    <p><small><%= new Date(rep.date).toLocaleString() %></small></p>
                  <% } %>
                <% }) %>
              </div>
            <% } %>

            <form action="/admin/review/reply/<%= product.id %>/<%= index %>" method="POST" style="margin-top: 5px;">
              <input type="text" name="comment" placeholder="Tulis balasan..." required>
              <button type="submit">
                <%= review.reply && review.reply.length > 0 ? 'Update' : 'Kirim' %>
              </button>
            </form>
          </div>
        <% }) %>
      <% } else { %>
        <p style="margin-left: 20px; color: #888;">Belum ada review.</p>
      <% } %>
    </div>
  <% }) %>

<% } %>